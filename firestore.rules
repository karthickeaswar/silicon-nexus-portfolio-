rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // visitors: anyone can write a new visit (analytics tracking)
    // but nobody can read (only admin via Cloud Functions with Admin SDK)
    match /visitors/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['page', 'referrer', 'userAgent', 'country', 'timestamp'])
                    && request.resource.data.page is string
                    && request.resource.data.page.size() <= 200;
      allow read, update, delete: if false;
    }

    // contacts: written via Cloud Functions Admin SDK (server-side only)
    match /contacts/{docId} {
      allow read, write: if false;
    }

    // All other documents: no access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
